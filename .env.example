# ─────────────────────────────────────────────────────
#  APP CONFIGURATION
# ─────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=your-secret-key-generate-with-openssl-rand-hex-32

# URLs (update these for production)
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-api.onrender.com

# ─────────────────────────────────────────────────────
#  GOOGLE OAUTH (for Google Sheets)
# ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-api.onrender.com/api/auth/google/callback

# ─────────────────────────────────────────────────────
#  ATLASSIAN OAUTH (for Jira)
# ─────────────────────────────────────────────────────
ATLASSIAN_CLIENT_ID=your-atlassian-client-id
ATLASSIAN_CLIENT_SECRET=your-atlassian-client-secret
ATLASSIAN_REDIRECT_URI=https://your-api.onrender.com/api/auth/atlassian/callback

# ─────────────────────────────────────────────────────
#  AI PROVIDERS (at least one required)
# ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
